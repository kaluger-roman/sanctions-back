generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

model Preferences {
  id                           Int @id @default(autoincrement())
  autoLogoutTime               Int @default(3600000)
  autoLogoutCheckTime          Int @default(600000)
  // count of active sessions per account without force login
  momentumOnlineDevicesPerUser Int @default(1)
}

model Sanction {
  id             Int    @id @default(autoincrement())
  sourceCountry  String
  sourceDocument String
  restriction    String
  code           String
  description    String
}

model User {
  id                           Int           @id @default(autoincrement())
  createdAt                    DateTime      @default(now())
  email                        String        @unique
  passwordHash                 String
  isAdmin                      Boolean       @default(false)
  recoverPasswordToken         String?
  recoverPasswordRequestTime   DateTime?
  name                         String
  surname                      String
  secondName                   String?
  phone                        String
  INN                          String?
  companyName                  String?
  category                     String
  isConfirmed                  Boolean       @default(false)
  registrationConfirmToken     String?
  lastPasswordChangeTime       DateTime?     @default(now())
  tarrifs                      UserTarrif[]
  UserSession                  UserSession[]
  // count of active sessions per account without force login
  momentumOnlineDevicesPerUser Int?          @default(1)
}

model UserSession {
  id               Int       @id @default(autoincrement())
  user             User      @relation(fields: [userId], references: [id])
  userId           Int
  token            String
  deviceId         String
  lastActivityTime DateTime? @default(now())
  createdAt        DateTime? @default(now())
  destroyedAt      DateTime?
}

model UserTarrif {
  id                      Int             @id @default(autoincrement())
  user                    User            @relation(fields: [userId], references: [id])
  tarrif                  Tarrif          @relation(fields: [tarrifId], references: [id])
  start                   DateTime?
  end                     DateTime?
  userId                  Int
  tarrifId                Int
  isUserNoticed           Boolean         @default(false)
  devices                 Device[]
  searchRequest           SearchRequest[]
  additionalRequestsCount Int             @default(0)
}

model SearchRequest {
  id           Int         @id @default(autoincrement())
  countries    String[]
  searchTypes  String[]
  restrictions String[]
  searchTags   String[]
  UserTarrif   UserTarrif? @relation(fields: [userTarrifId], references: [id])
  userTarrifId Int?
}

model Device {
  id         String       @id
  UserTarrif UserTarrif[]
}

model Tarrif {
  id               Int          @id @default(autoincrement())
  identifier       String       @unique
  // in months
  duration         Int?
  allowedRequests  Int?
  allowedDevices   Int?
  // in rubles
  price            Int?
  allowedCountries String[]
  UserTarrif       UserTarrif[]
}

model PendingPayment {
  id String @id
}
