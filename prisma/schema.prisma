generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

model Sanction {
  id             Int    @id @default(autoincrement())
  sourceCountry  String
  sourceDocument String
  restriction    String
  code           String
  description    String
}

model User {
  id                         Int       @id @default(autoincrement())
  email                      String    @unique
  passwordHash               String
  isAdmin                    Boolean   @default(false)
  recoverPasswordToken       String?
  recoverPasswordRequestTime DateTime?
  name                       String
  surname                    String
  secondName                 String?
  phone                      String
  INN                        String?
  companyName                String?
  category                   String
  isConfirmed                Boolean   @default(false)
  registrationConfirmToken   String?
  lastPasswordChangeTime     DateTime? @default(now())
}
