generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

model Sanction {
  id             Int    @id @default(autoincrement())
  sourceCountry  String
  sourceDocument String
  restriction    String
  code           String
  description    String
}

model User {
  id                         Int          @id @default(autoincrement())
  email                      String       @unique
  passwordHash               String
  isAdmin                    Boolean      @default(false)
  recoverPasswordToken       String?
  recoverPasswordRequestTime DateTime?
  name                       String
  surname                    String
  secondName                 String?
  phone                      String
  INN                        String?
  companyName                String?
  category                   String
  isConfirmed                Boolean      @default(false)
  registrationConfirmToken   String?
  lastPasswordChangeTime     DateTime?    @default(now())
  tarrifs                    UserTarrif[]
}

model UserTarrif {
  id            Int       @id @default(autoincrement())
  user          User      @relation(fields: [userId], references: [id])
  tarrif        Tarrif    @relation(fields: [tarrifId], references: [id])
  start         DateTime?
  end           DateTime?
  userId        Int
  tarrifId      Int
  isUserNoticed Boolean   @default(false)
  doneRequests  Int       @default(0)
}

model Tarrif {
  id               Int          @id @default(autoincrement())
  identifier       String       @unique
  // in months
  duration         Int?
  allowedRequests  Int?
  allowedDevices   Int?
  // in rubles
  price            Int?
  allowedCountries String[]
  UserTarrif       UserTarrif[]
}

model PendingPayment {
  id String @id
}
