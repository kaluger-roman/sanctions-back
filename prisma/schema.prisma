generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

model Sanction {
  id             Int    @id @default(autoincrement())
  sourceCountry  String
  sourceDocument String
  restriction    String
  code           String
  description    String
}

model User {
  id Int @id
}
