generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citus, citus_columnar, pg_trgm]
}

model Preferences {
  id                               Int @id @default(autoincrement())
  autoLogoutTime                   Int @default(3600000)
  autoLogoutCheckTime              Int @default(600000)
  // count of active sessions per account without force login
  momentumOnlineDevicesPerJurUser  Int @default(3)
  momentumOnlineDevicesPerPhysUser Int @default(1)
  // максимальное количество отчетов на пользователя
  maxUserReports                   Int @default(100)
  // максимальное количество отчетов не привязанных к пользователю
  maxUnlinkedReports               Int @default(500)
  // максимальное количество тегов в Excel-файле поискового запроса
  maxExcelTags                     Int @default(1000)
  // максимальное количество тегов для веб-интерфейса
  maxWebViewTagsCount              Int @default(50)
}

model Sanction {
  id                   Int    @id @default(autoincrement())
  sourceCountry        String
  sourceDocument       String
  restriction          String
  code                 String
  description          String
  descriptionRussian   String @default("")
  sourceLink           String @default("")
  sourceDocumentOrigin String @default("")

  @@index([description(ops: raw("gin_trgm_ops"))], map: "description_trgm_idx", type: Gin)
  @@index([descriptionRussian(ops: raw("gin_trgm_ops"))], map: "descriptionrussian_trgm_idx", type: Gin)
  @@index([restriction], map: "idx_restriction")
  @@index([sourceCountry], map: "idx_sourcecountry")
  @@index([sourceDocumentOrigin], map: "idx_sourcedocumentorigin")
}

model CounterSanction {
  id                  Int    @id @default(autoincrement())
  code                String
  description         String
  exception           String @default("")
  sourceDocument      String
  restriction         String
  sourceDocumentShort String @default("")

  @@index([description(ops: raw("gin_trgm_ops"))], map: "countersanction_description_trgm_idx", type: Gin)
  @@index([exception(ops: raw("gin_trgm_ops"))], map: "countersanction_exception_trgm_idx", type: Gin)
  @@index([restriction], map: "idx_countersanction_restriction")
  @@index([sourceDocumentShort], map: "idx_countersanction_sourcedocumentshort")
}

model User {
  id                           Int                     @id @default(autoincrement())
  createdAt                    DateTime                @default(now())
  email                        String                  @unique
  passwordHash                 String
  isAdmin                      Boolean                 @default(false)
  recoverPasswordToken         String?
  recoverPasswordRequestTime   DateTime?
  name                         String
  surname                      String
  secondName                   String?
  phone                        String
  INN                          String?
  companyName                  String?
  category                     String
  isConfirmed                  Boolean                 @default(false)
  registrationConfirmToken     String?
  lastPasswordChangeTime       DateTime?               @default(now())
  tarrifs                      UserTarrif[]
  UserSession                  UserSession[]
  reports                      Report[]
  counterSanctionReports       CounterSanctionReport[]
  // count of active sessions per account without force login
  momentumOnlineDevicesPerUser Int?                    @default(3)
}

model UserSession {
  id               Int       @id @default(autoincrement())
  user             User      @relation(fields: [userId], references: [id])
  userId           Int
  token            String
  deviceId         String
  lastActivityTime DateTime? @default(now())
  createdAt        DateTime? @default(now())
  destroyedAt      DateTime?
}

model UserTarrif {
  id                           Int                            @id @default(autoincrement())
  user                         User                           @relation(fields: [userId], references: [id])
  tarrif                       Tarrif                         @relation(fields: [tarrifId], references: [id])
  start                        DateTime?
  end                          DateTime?
  userId                       Int
  tarrifId                     Int
  isUserNoticed                Boolean                        @default(false)
  devices                      Device[]
  searchRequest                SearchRequest[]
  counterSanctionSearchRequest CounterSanctionSearchRequest[]
  additionalRequestsCount      Int                            @default(0)
}

model SearchRequest {
  id                    Int         @id @default(autoincrement())
  countries             String[]
  searchTypes           String[]
  restrictions          String[]
  sourceDocumentOrigins String[]
  searchTags            String[]
  UserTarrif            UserTarrif? @relation(fields: [userTarrifId], references: [id])
  userTarrifId          Int?
  searchLanguage        String      @default("")
}

model Device {
  id         String       @id
  UserTarrif UserTarrif[]
}

model Tarrif {
  id                            Int          @id @default(autoincrement())
  identifier                    String       @unique
  // in months
  duration                      Int?
  allowedRequests               Int?
  allowedDevices                Int?
  // in rubles
  price                         Int?
  allowedCountries              String[]
  allowedCounterSanctionSources String[]     @default([])
  UserTarrif                    UserTarrif[]
}

model Report {
  id                    String   @id @default(uuid())
  title                 String?
  createdAt             DateTime @default(now())
  user                  User?    @relation(fields: [userId], references: [id])
  userId                Int?
  countries             String[]
  searchTypes           String[]
  restrictions          String[]
  sourceDocumentOrigins String[]
  searchTags            String[]
  searchLanguage        String   @default("en")
  isDeleted             Boolean  @default(false)
}

model PendingPayment {
  id String @id
}

model CounterSanctionSearchRequest {
  id                   Int         @id @default(autoincrement())
  searchTypes          String[]
  restrictions         String[]
  sourceDocumentShorts String[]
  searchTags           String[]
  UserTarrif           UserTarrif? @relation(fields: [userTarrifId], references: [id])
  userTarrifId         Int?
}

model CounterSanctionReport {
  id                   String   @id @default(uuid())
  title                String?
  createdAt            DateTime @default(now())
  user                 User?    @relation(fields: [userId], references: [id])
  userId               Int?
  searchTypes          String[]
  restrictions         String[]
  sourceDocumentShorts String[]
  searchTags           String[]
  isDeleted            Boolean  @default(false)
}
